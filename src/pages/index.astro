---
// inspir.uk landing page
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="inspir.uk: the new home of inspir. Building AI-first learning tools for students. 1M+ users, open source, coming soon." />
    <meta property="og:title" content="inspir: The new home of inspir" />
    <meta property="og:description" content="Building AI-first learning tools for students. One-to-one tutoring, just way smarter." />
    <title>inspir: Building the future of learning</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  </head>

  <body>

    <!-- NAV -->
    <nav>
      <div class="container nav-inner">
        <span class="logo">inspir</span>
        <div class="nav-links">
          <a href="#building">Building</a>
          <a href="#platform">Platform</a>
          <a href="#history">History</a>
          <a href="#press">Press</a>
          <a href="https://inspirlearning.com" target="_blank" rel="noopener" class="nav-cta">Try inspir ↗</a>
        </div>
      </div>
    </nav>

    <!-- HERO -->
    <section id="hero">
      <div class="container hero-inner">
        <h1>The new home<br />of inspir.</h1>
        <p class="hero-sub">
          Building AI-first learning tools for students.<br />
          One-to-one tutoring, just way smarter.
        </p>
        <div class="hero-actions">
          <a href="https://inspirlearning.com" target="_blank" rel="noopener" class="btn-primary">
            Visit inspirlearning.com ↗
          </a>
          <a href="#building" class="btn-ghost">See what we're building</a>
        </div>
        <div class="hero-stat">
          <span class="stat-num">1,000,000+</span>
          <span class="stat-label">students learning on inspir today</span>
        </div>
      </div>
    </section>

    <!-- WHAT WE'RE BUILDING -->
    <section id="building">
      <div class="container">
        <div class="section-label">Open Source · GitHub</div>
        <h2>What we're building</h2>
        <p class="section-sub">
          inspir's next generation is being built in the open on GitHub.<br />
          Star the repos, follow along, or contribute.
        </p>

        <div class="repo-grid">
          <div class="repo-card">
            <div class="card-header">
              <span class="coming-soon-badge">Coming Soon</span>
              <a href="https://github.com/makriman/ai-study-platform" target="_blank" rel="noopener" class="github-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                </svg>
                makriman/ai-study-platform
              </a>
            </div>
            <h3>AI Study Platform</h3>
            <p>A revolutionary AI-powered chat interface for students. Real-time streaming tutoring via Claude, with 15 built-in study tools and an inverted IDE-inspired layout.</p>
            <div class="stack-tags">
              <span>React 19</span>
              <span>Claude API</span>
              <span>Supabase</span>
              <span>Node.js</span>
            </div>
          </div>

          <div class="repo-card">
            <div class="card-header">
              <span class="coming-soon-badge">Coming Soon</span>
              <a href="https://github.com/makriman/inspir-platform" target="_blank" rel="noopener" class="github-link">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
                </svg>
                makriman/inspir-platform
              </a>
            </div>
            <h3>inspir Platform</h3>
            <p>The full inspir experience: AI study companion with age-appropriate content filtering, conversation management, and a macOS dock-inspired study toolbar.</p>
            <div class="stack-tags">
              <span>React 19</span>
              <span>Claude API</span>
              <span>Supabase</span>
              <span>Framer Motion</span>
            </div>
          </div>
        </div>

        <!-- Contribute banner -->
        <div class="contribute-banner">
          <div class="contribute-text">
            <p class="contribute-heading">Built in the open. Contributions welcome.</p>
            <p class="contribute-sub">Both platforms are open source on GitHub. Star the repos, open issues, or submit a pull request.</p>
          </div>
          <div class="contribute-links">
            <a href="https://github.com/makriman/ai-study-platform" target="_blank" rel="noopener" class="contribute-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
              ai-study-platform
            </a>
            <a href="https://github.com/makriman/inspir-platform" target="_blank" rel="noopener" class="contribute-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
              </svg>
              inspir-platform
            </a>
          </div>
        </div>

        <!-- Feature highlights -->
        <div class="features-block">
          <h3 class="features-title">15 study tools, built in</h3>
          <div class="features-grid">
            {[
              "Quiz Generator", "Flashcards", "Practice Tests", "Study Timer", "Habit Tracker",
              "Draw & Sketch", "Math Solver", "Science Lab", "Image Analysis", "Concept Explainer",
              "Visual Learning", "Notes Sync", "AI Planner", "Goal Setter", "Study Music"
            ].map(tool => (
              <div class="feature-item">
                <span class="feature-dot"></span>
                {tool}
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- LIVE NOW -->
    <section id="platform" class="platform-section">
      <div class="container">
        <div class="platform-inner">
          <div class="platform-text">
            <div class="live-dot-wrap">
              <span class="live-dot"></span>
              <span class="live-label">Live now</span>
            </div>
            <h2>inspir is live today</h2>
            <p>
              While inspir.uk is being built, the platform is live and free at
              <strong>inspirlearning.com</strong>: 1M+ students, AI-powered tutoring, no account needed.
            </p>
            <a href="https://inspirlearning.com" target="_blank" rel="noopener" class="btn-white">
              Go to inspirlearning.com ↗
            </a>
          </div>
          <div class="platform-stats">
            <div class="p-stat">
              <span class="p-stat-num">1M+</span>
              <span class="p-stat-label">registered users</span>
            </div>
            <div class="p-stat">
              <span class="p-stat-num">2013</span>
              <span class="p-stat-label">founded</span>
            </div>
            <div class="p-stat">
              <span class="p-stat-num">Free</span>
              <span class="p-stat-label">always</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- HISTORY -->
    <section id="history">
      <div class="container">
        <div class="section-label">Since 2013</div>
        <h2>Our history</h2>

        <div class="timeline">

          <div class="timeline-item">
            <div class="tl-marker"><span class="tl-dot"></span></div>
            <div class="tl-year">2013</div>
            <div class="tl-content">
              <h4>Started</h4>
              <p>Founded as a student-led initiative in India to make extracurricular learning more accessible. Built custom buzzer hardware from scratch and grew an online community.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="tl-marker"><span class="tl-dot"></span></div>
            <div class="tl-year">2014</div>
            <div class="tl-content">
              <h4>First Inspire Offline Quiz</h4>
              <p>Took inspir off the screen and into the room. The first in-person quiz event, bringing students together to compete and learn.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="tl-marker"><span class="tl-dot"></span></div>
            <div class="tl-year">2014</div>
            <div class="tl-content">
              <h4>Quiz Nexus</h4>
              <p>Launched the first Inspire Quiz Nexus, an offline quiz format that became a template for future events.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="tl-marker"><span class="tl-dot"></span></div>
            <div class="tl-year">2015</div>
            <div class="tl-content">
              <h4>NLP on Facebook</h4>
              <p>Launched a natural language processing system on Facebook for scoring and hosting quizzes automatically: an early experiment in using AI to run educational events at scale.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="tl-marker"><span class="tl-dot"></span></div>
            <div class="tl-year">2016</div>
            <div class="tl-content">
              <h4>Extracurricular Training</h4>
              <p>Expanded beyond quizzes into structured extracurricular activity training sessions, helping students develop skills outside the classroom.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="tl-marker"><span class="tl-dot"></span></div>
            <div class="tl-year">2019</div>
            <div class="tl-content">
              <h4>ICSE Frank Anthony Quiz, Delhi Regionals</h4>
              <p>Hosted the ICSE Frank Anthony Quiz Delhi Regionals, one of India's most prestigious school quiz competitions.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="tl-marker"><span class="tl-dot"></span></div>
            <div class="tl-year">2022</div>
            <div class="tl-content">
              <h4>AI/NLP Tutoring Platform</h4>
              <p>Evolved into a full AI-powered tutoring platform using natural language processing, enabling learners of all ages to ask questions and receive detailed, real-time responses. Making one-to-one tutoring accessible to everyone.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="tl-marker"><span class="tl-dot"></span></div>
            <div class="tl-year">2024</div>
            <div class="tl-content">
              <h4>A new home</h4>
              <p>inspir started on <strong>inspir.app</strong>. We had to sell that domain to keep the platform running, so we moved to <strong>inspirlearning.com</strong>, which is where it lives today. Now we're coming back: <strong>inspir.uk</strong> is the home inspir always deserved.</p>
            </div>
          </div>

          <div class="timeline-item">
            <div class="tl-marker"><span class="tl-dot"></span></div>
            <div class="tl-year">2025</div>
            <div class="tl-content">
              <h4>One Million Students and Recognition</h4>
              <p>1,000,000+ registered users and growing, built without institutional funding. Awarded Jury's Choice at the <a href="https://nirantk.com/community/deephackdemos/" target="_blank" rel="noopener">DeepHack AI/NLP Demo</a> showcase. Featured in <a href="https://deccanbusiness.com/where-learning-becomes-universal-inspirs-vision-to-make-education-free-fun-and-accessible-for-everyone/" target="_blank" rel="noopener">Deccan Business</a> and syndicated on <a href="https://dhunt.in/12OTez" target="_blank" rel="noopener">Dailyhunt</a>.</p>
            </div>
          </div>

          <div class="timeline-item timeline-future">
            <div class="tl-marker"><span class="tl-dot tl-dot--future"></span></div>
            <div class="tl-year">2026</div>
            <div class="tl-content">
              <h4>inspir.uk: The next chapter</h4>
              <p>Two new open-source AI-first platforms launching at inspir.uk, built with React 19, Claude API, and 15 integrated study tools. Follow along on <a href="https://github.com/makriman/ai-study-platform" target="_blank" rel="noopener">GitHub</a>.</p>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- PRESS -->
    <section id="press">
      <div class="container">
        <div class="section-label">Coverage</div>
        <h2>Press</h2>
        <div class="press-grid">

          <a href="https://deccanbusiness.com/where-learning-becomes-universal-inspirs-vision-to-make-education-free-fun-and-accessible-for-everyone/"
             target="_blank" rel="noopener" class="press-card">
            <div class="press-pub">Deccan Business</div>
            <p class="press-headline">"Where Learning Becomes Universal: inspir's Vision to Make Education Free, Fun and Accessible for Everyone"</p>
            <div class="press-footer">
              <span class="press-date">December 16, 2025</span>
              <span class="press-cta">Read article ↗</span>
            </div>
          </a>

          <a href="https://dhunt.in/12OTez"
             target="_blank" rel="noopener" class="press-card">
            <div class="press-pub">Dailyhunt</div>
            <p class="press-headline">inspir's vision to make learning universal, free, and powered by AI. Syndicated national coverage.</p>
            <div class="press-footer">
              <span class="press-date">December 2025</span>
              <span class="press-cta">Read article ↗</span>
            </div>
          </a>

          <a href="https://nirantk.com/community/deephackdemos/"
             target="_blank" rel="noopener" class="press-card press-card--award">
            <div class="press-pub">🏆 DeepHack · nirantk.com</div>
            <p class="press-headline">Jury's Choice: AI/NLP Demo Showcase. Recognised for using NLP to democratise one-to-one tutoring and make education accessible for all.</p>
            <div class="press-footer">
              <span class="press-date">DeepHack Demo Day</span>
              <span class="press-cta">View demo ↗</span>
            </div>
          </a>

        </div>
      </div>
    </section>

    <!-- FOOTER -->
    <footer>
      <div class="container footer-inner">
        <div class="footer-brand">
          <span class="logo footer-logo">inspir</span>
          <p>The new home of inspir, coming soon on inspir.uk</p>
        </div>
        <div class="footer-links">
          <a href="https://inspirlearning.com" target="_blank" rel="noopener">inspirlearning.com</a>
          <a href="https://github.com/makriman/ai-study-platform" target="_blank" rel="noopener">ai-study-platform</a>
          <a href="https://github.com/makriman/inspir-platform" target="_blank" rel="noopener">inspir-platform</a>
        </div>
        <p class="footer-copy">© 2026 inspir. Built in the open.</p>
      </div>
    </footer>

  </body>
</html>

<style is:global>
  /* Reset */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:          #f5f5f4;
    --blue:        #1e40af;
    --blue-dark:   #1e3a8a;
    --blue-tint:   #dbeafe;
    --blue-mid:    #93c5fd;
    --text:        #111827;
    --muted:       #6b7280;
    --border:      #e5e7eb;
    --white:       #ffffff;
    --radius:      12px;
    --shadow-card: 0 1px 3px rgba(0,0,0,.05), 0 4px 16px rgba(0,0,0,.06);
    --shadow-hover: 0 4px 12px rgba(0,0,0,.08), 0 16px 40px rgba(0,0,0,.1);
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; text-decoration: none; }

  .container {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* NAV */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(245, 245, 244, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--blue);
    letter-spacing: -0.03em;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-links a {
    font-size: .875rem;
    font-weight: 500;
    color: var(--muted);
    transition: color .15s;
  }

  .nav-links a:hover { color: var(--text); }

  .nav-cta {
    background: var(--blue) !important;
    color: var(--white) !important;
    padding: 7px 16px;
    border-radius: 8px;
    font-weight: 600 !important;
    transition: background .15s !important;
  }

  .nav-cta:hover { background: var(--blue-dark) !important; color: var(--white) !important; }

  /* HERO */
  #hero {
    padding: 100px 0 88px;
    text-align: center;
  }

  h1 {
    font-size: clamp(2.75rem, 7vw, 5rem);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--text);
    margin-bottom: 24px;
  }

  .hero-sub {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--muted);
    max-width: 440px;
    margin: 0 auto 40px;
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 56px;
  }

  .btn-primary {
    display: inline-block;
    background: var(--blue);
    color: var(--white);
    font-weight: 600;
    font-size: .9375rem;
    padding: 12px 24px;
    border-radius: var(--radius);
    transition: background .15s, transform .15s;
  }

  .btn-primary:hover {
    background: var(--blue-dark);
    transform: translateY(-1px);
  }

  .btn-ghost {
    display: inline-block;
    background: var(--white);
    color: var(--text);
    font-weight: 600;
    font-size: .9375rem;
    padding: 12px 24px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    transition: border-color .15s, transform .15s;
  }

  .btn-ghost:hover {
    border-color: var(--blue-mid);
    transform: translateY(-1px);
  }

  .btn-white {
    display: inline-block;
    background: var(--white);
    color: var(--blue);
    font-weight: 700;
    font-size: .9375rem;
    padding: 12px 24px;
    border-radius: var(--radius);
    transition: background .15s, transform .15s;
  }

  .btn-white:hover {
    background: var(--blue-tint);
    transform: translateY(-1px);
  }

  .hero-stat {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .stat-num {
    font-size: 2.5rem;
    font-weight: 900;
    color: var(--blue);
    letter-spacing: -0.04em;
  }

  .stat-label {
    font-size: .875rem;
    color: var(--muted);
    font-weight: 500;
  }

  /* SHARED SECTION */
  section { padding: 88px 0; }

  .section-label {
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 12px;
  }

  h2 {
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 16px;
  }

  .section-sub {
    font-size: 1.0625rem;
    color: var(--muted);
